# Public site URL (metadata, sitemap, JSON-LD)
NEXT_PUBLIC_SITE_URL=https://vogobyfame.com

# Database
# Local dev (SQLite):
DATABASE_URL="file:./dev.db"
#
# Netlify production (PostgreSQL via Netlify DB):
# 1. Netlify → Site → Extensions → Add "Netlify DB"
# 2. Site settings → Environment variables → add DATABASE_URL = (paste the Postgres URL from Netlify DB)
#    Build also accepts NETLIFY_DATABASE_URL automatically during deploy.
# 3. Redeploy — build runs prisma db push + seed on PostgreSQL
#
# Railway production:
# 1. `railway add --database postgres` and link DATABASE_URL to the app service
# 2. Set env vars (see scripts/railway-sync-env.cjs) — set NEXT_PUBLIC_SITE_URL to the Railway domain
# 3. Push to master or `railway up` — release command runs db push + seed
# IMPORTANT: Do NOT set DATABASE_URL=file:./dev.db in production — use postgres:// or static catalog only.

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=

# Optional: Google OAuth
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Optional: Stripe payments
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Optional: analytics (Stage 5)
# NEXT_PUBLIC_GA_ID=
# NEXT_PUBLIC_META_PIXEL_ID=

# Optional: newsletter email (Resend)
# RESEND_API_KEY=

# Virtual Fitting Room — REQUIRED for AI try-on (server-only, never expose to client)
# Provider: gemini | nvidia | local (admin panel can override gemini vs local at runtime)
IMAGE_PROVIDER=gemini

# Local FLUX Klein via ComfyUI (when admin selects Local, or IMAGE_PROVIDER=local)
COMFYUI_BASE_URL=http://127.0.0.1:8188
COMFYUI_REQUEST_TIMEOUT_MS=180000
COMFYUI_MEGAPIXELS=0.5
COMFYUI_CFG=1.0
COMFYUI_STEPS=6

# Fitting room result storage (auto-detected on Netlify/Vercel/Railway/production):
# FITTING_ROOM_MEMORY_STORAGE=true  — force base64 data URLs (recommended on Railway)
# FITTING_ROOM_DISK_STORAGE=true    — force disk under public/uploads/fitting-room/ (persistent volume only)

# Gemini (https://aistudio.google.com/apikey)
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
GEMINI_REQUEST_TIMEOUT_MS=120000

# NVIDIA NIM (https://build.nvidia.com — create key with "Public API Endpoints" scope)
# Hosted FLUX Kontext trial only accepts demo images; custom photos use Gemini automatically when GEMINI_API_KEY is set.
# Set NVIDIA_ATTEMPT_CUSTOM_PHOTOS=true to attempt NVIDIA first (may 422, then fallback to Gemini).
# Set IMAGE_PROVIDER=nvidia and add NVIDIA_API_KEY, then restart: npm run dev
#
# Models (set NVIDIA_IMAGE_MODEL):
#   FLUX Kontext (default): black-forest-labs/flux.1-kontext-dev — person photo + text prompt
#   Qwen Image Edit: qwen/qwen-image-edit-2511 — POST integrate.api.nvidia.com/v1/images/edits (model: qwen-image-edit-2511)
NVIDIA_API_KEY=
NVIDIA_IMAGE_MODEL=black-forest-labs/flux.1-kontext-dev
# NVIDIA_IMAGE_MODEL=qwen/qwen-image-edit-2511
NVIDIA_API_BASE_URL=https://ai.api.nvidia.com/v1
NVIDIA_OPENAI_API_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_REQUEST_TIMEOUT_MS=120000
# If dev shows missing .next chunks, run: npm run dev:clean
# NVIDIA_QWEN_USE_GARMENT_IMAGE=true
# Optional: NVIDIA_ASPECT_RATIO=match_input_image, NVIDIA_STEPS=30, NVIDIA_CFG_SCALE=3, NVIDIA_SEED=0

IMAGE_HTTP_429_MAX_ATTEMPTS=1
# Optional: GEMINI_API_BASE_URL, GEMINI_CONFIG_PATH, GEMINI_GENERATION_CONFIG_JSON
# Optional: GEMINI_API_KEY_HEADER=x-goog-api-key

# Seed admin password (local dev only)
# SEED_ADMIN_PASSWORD=Admin123!
