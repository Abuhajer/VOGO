// Production schema (Railway / PostgreSQL). Local dev uses schema.prisma (SQLite).
generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String             @id @default(cuid())
  email           String             @unique
  passwordHash    String?
  name            String?
  phone           String?
  role            String             @default("CUSTOMER")
  preferredLocale String             @default("ar")
  emailVerified   DateTime?
  image           String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  accounts        Account[]
  sessions        Session[]
  orders          Order[]
  customerNotes   CustomerNote[]     @relation("CustomerSubject")
  authoredNotes   CustomerNote[]     @relation("NoteAuthor")
  feedback        CustomerFeedback[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Collection {
  id         String      @id @default(cuid())
  slug       String      @unique
  nameAr     String
  nameEn     String
  sortOrder  Int         @default(0)
  active     Boolean     @default(true)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  products   Product[]
  promotions Promotion[]
}

model Product {
  id                String             @id @default(cuid())
  slug              String             @unique
  sku               String             @unique
  nameAr            String
  nameEn            String
  descAr            String
  descEn            String
  price             Int
  imageSrc          String
  sizeChartJson     String?
  customSizeEnabled Boolean            @default(true)
  active            Boolean            @default(true)
  featuredCarousel  Boolean            @default(false)
  collectionId      String?
  collection        Collection?        @relation(fields: [collectionId], references: [id])
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  orderItems        OrderItem[]
  promotionTargets  PromotionProduct[]
}

model Order {
  id              String             @id @default(cuid())
  orderNumber     String             @unique
  userId          String?
  user            User?              @relation(fields: [userId], references: [id])
  status          String             @default("PENDING")
  paymentMethod   String
  stripeSessionId String?
  subtotal        Int
  discountAmount  Int                @default(0)
  promoCode       String?
  promotionId     String?
  promotion       Promotion?         @relation(fields: [promotionId], references: [id], onDelete: SetNull)
  total           Int
  currency        String             @default("JOD")
  customerName    String
  customerEmail   String
  customerPhone   String
  notes           String?
  locale          String             @default("ar")
  items           OrderItem[]
  feedback        CustomerFeedback[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
}

model OrderItem {
  id                     String  @id @default(cuid())
  orderId                String
  order                  Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId              String
  product                Product @relation(fields: [productId], references: [id])
  quantity               Int
  unitPrice              Int
  nameAr                 String
  nameEn                 String
  sizeCode               String?
  sizeLabelEn            String?
  sizeLabelAr            String?
  customMeasurementsJson String?
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  locale    String   @default("ar")
  createdAt DateTime @default(now())
}

model FittingRoomAvatar {
  id        String   @id @default(cuid())
  slug      String   @unique
  labelEn   String
  labelAr   String
  imageSrc  String
  sortOrder Int      @default(0)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model CustomerNote {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation("CustomerSubject", fields: [userId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation("NoteAuthor", fields: [authorId], references: [id])
  content   String
  createdAt DateTime @default(now())
}

model CustomerFeedback {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderId   String?
  order     Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)
  rating    Int?
  comment   String
  source    String   @default("admin")
  createdAt DateTime @default(now())
}

model Promotion {
  id            String             @id @default(cuid())
  nameEn        String
  nameAr        String
  code          String?            @unique
  discountType  String
  discountValue Int
  scope         String
  collectionId  String?
  collection    Collection?        @relation(fields: [collectionId], references: [id], onDelete: SetNull)
  startsAt      DateTime?
  endsAt        DateTime?
  active        Boolean            @default(true)
  usageLimit    Int?
  usageCount    Int                @default(0)
  minSubtotal   Int?
  badgeEn       String?
  badgeAr       String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  targets       PromotionProduct[]
  orders        Order[]
}

model PromotionProduct {
  promotionId String
  productId   String
  promotion   Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([promotionId, productId])
}
