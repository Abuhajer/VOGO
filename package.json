{
  "name": "vogo-by-fame",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "node node_modules/next/dist/bin/next dev",
    "dev:clean": "node scripts/dev-clean.mjs",
    "build": "next build",
    "build:netlify": "node scripts/netlify-build.mjs",
    "start": "next start",
    "start:clean": "node scripts/start-clean.mjs",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "validate": "npm run lint && npm run typecheck && npm run build",
    "postinstall": "node scripts/postinstall-prisma.mjs",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "products:fetch-images": "node scripts/fetch-product-images.mjs",
    "products:restore-images": "node scripts/restore-original-product-images.mjs",
    "tunnel": "node scripts/tunnel-quick.mjs",
    "tunnel:run": "cloudflared tunnel run vogo-by-fame"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@gsap/react": "^2.1.2",
    "@netlify/database": "^1.0.0",
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^3.0.3",
    "framer-motion": "^12.40.0",
    "gsap": "^3.15.0",
    "next": "14.2.35",
    "next-auth": "^5.0.0-beta.31",
    "next-intl": "^4.13.0",
    "react": "^18",
    "react-dom": "^18",
    "sharp": "^0.35.2",
    "stripe": "^22.2.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.21.0",
    "typescript": "^5"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  }
}
